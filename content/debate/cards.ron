// =============================================================================
// DEBATE CLUB CARDS -- Arguments, Defenses, and Dirty Tricks
// =============================================================================
//
// The Debate Club is a Slay the Spire-inspired card minigame played between
// runs. Players build a deck of "Argument" cards and face NPC opponents.
//
// Resource: Rhetoric Points (RP) -- starts at 3, increases by 1 per turn.
// Win condition: reduce opponent's Credibility to 0.
// Win reward: next-run modifiers (bonus damage, extra loot, harder enemies).
//
// Card categories:
//   - Attack: damage opponent's Credibility
//   - Block: reduce incoming Credibility damage
//   - Special: unique effects, combos, dirty tricks
//   - Draw: gain extra cards
//
// "Your argument is invalid. My argument is also invalid. That's politics."
// =============================================================================

DebateCards(
    cards: [

        // =====================================================================
        // ATTACK CARDS -- Damage opponent's Credibility
        // =====================================================================

        // --- Basic attacks ---
        (
            key: "ad_hominem",
            name: "Ad Hominem",
            category: "Attack",
            rp_cost: 1,
            damage: 6,
            block: 0,
            description: "Attack your opponent personally instead of addressing their argument. It's wrong, but it works.",
            flavor_text: "\"Your tie is ugly and therefore your fiscal policy is wrong.\"",
            special_effect: None,
        ),

        (
            key: "straw_man_fallacy",
            name: "Straw Man Fallacy",
            category: "Attack",
            rp_cost: 1,
            damage: 4,
            block: 0,
            description: "Misrepresent your opponent's argument, then attack the misrepresentation. Classic.",
            flavor_text: "\"So what you're REALLY saying is that you hate puppies. Interesting.\"",
            special_effect: Some("If opponent played a Block card last turn, deal double damage (they blocked something you didn't actually argue)."),
        ),

        (
            key: "appeal_to_authority",
            name: "Appeal to Authority",
            category: "Attack",
            rp_cost: 2,
            damage: 8,
            block: 0,
            description: "Cite an authority figure who agrees with you. Whether they're qualified is irrelevant.",
            flavor_text: "\"As the Commissioner himself once said... actually, I'm paraphrasing. Heavily.\"",
            special_effect: None,
        ),

        (
            key: "slippery_slope",
            name: "Slippery Slope",
            category: "Attack",
            rp_cost: 2,
            damage: 5,
            block: 0,
            description: "Argue that one small change will inevitably lead to catastrophe. Apply 2 turns of 'Dread' (2 damage per turn).",
            flavor_text: "\"If we lower this tax rate by 1%, next thing you know we'll be living in anarchy!\"",
            special_effect: Some("Apply 'Dread' debuff: 2 Credibility damage per turn for 2 turns."),
        ),

        (
            key: "whataboutism",
            name: "Whataboutism",
            category: "Attack",
            rp_cost: 1,
            damage: 5,
            block: 0,
            description: "Deflect criticism by pointing at someone else's failures. Universal political technique.",
            flavor_text: "\"But what about THEIR tax returns? Have you seen THOSE?\"",
            special_effect: Some("If you took Credibility damage last turn, deal +3 bonus damage."),
        ),

        (
            key: "gotcha_question",
            name: "Gotcha Question",
            category: "Attack",
            rp_cost: 2,
            damage: 7,
            block: 0,
            description: "Ask a question that has no good answer. Either response damages their credibility.",
            flavor_text: "\"So, do you support waste, or do you support cuts? Choose carefully.\"",
            special_effect: Some("Opponent's Block is 30% less effective next turn."),
        ),

        (
            key: "cherry_picking",
            name: "Cherry Picking",
            category: "Attack",
            rp_cost: 1,
            damage: 3,
            block: 0,
            description: "Select only the data that supports your argument. Draw 1 card.",
            flavor_text: "\"The numbers clearly show-- no, not THOSE numbers. THESE numbers.\"",
            special_effect: Some("Draw 1 card."),
        ),

        (
            key: "false_dichotomy",
            name: "False Dichotomy",
            category: "Attack",
            rp_cost: 2,
            damage: 9,
            block: 0,
            description: "Present only two options when many exist. Both options are bad for your opponent.",
            flavor_text: "\"You either agree with me, or you admit you're wrong. Those are the only options.\"",
            special_effect: None,
        ),

        (
            key: "emotional_appeal",
            name: "Emotional Appeal",
            category: "Attack",
            rp_cost: 3,
            damage: 12,
            block: 0,
            description: "Bypass logic entirely. Go straight for the feelings. High cost, high impact.",
            flavor_text: "\"Think of the CHILDREN! The taxpaying children!\"",
            special_effect: None,
        ),

        (
            key: "gish_gallop",
            name: "Gish Gallop",
            category: "Attack",
            rp_cost: 3,
            damage: 4,
            block: 0,
            description: "Overwhelm your opponent with so many weak arguments they can't address them all. Hit 3 times for 4 damage each.",
            flavor_text: "\"Point one! Point two! Point seven! Point twelve! Point-- are you writing these down?\"",
            special_effect: Some("Attacks 3 times. Each hit is a separate instance of 4 damage (Block applies per hit)."),
        ),

        // =====================================================================
        // BLOCK CARDS -- Defend your Credibility
        // =====================================================================

        (
            key: "burden_of_proof",
            name: "Burden of Proof",
            category: "Block",
            rp_cost: 1,
            damage: 0,
            block: 7,
            description: "Demand your opponent prove their claims. Forces them to spend resources on evidence.",
            flavor_text: "\"Interesting claim. Now prove it. With FORMS.\"",
            special_effect: None,
        ),

        (
            key: "constitutional_defense",
            name: "Constitutional Defense",
            category: "Block",
            rp_cost: 2,
            damage: 0,
            block: 12,
            description: "Invoke the constitution. Nobody argues with the constitution. (They do, but it buys time.)",
            flavor_text: "\"I invoke my rights under the Taxeclast Revenue Constitution, Amendment 47, Subsection... uh... the good one.\"",
            special_effect: None,
        ),

        (
            key: "no_comment",
            name: "No Comment",
            category: "Block",
            rp_cost: 0,
            damage: 0,
            block: 4,
            description: "Say nothing. Surprisingly effective. Costs 0 RP.",
            flavor_text: "\"...\"",
            special_effect: None,
        ),

        (
            key: "plausible_deniability",
            name: "Plausible Deniability",
            category: "Block",
            rp_cost: 1,
            damage: 0,
            block: 5,
            description: "Deny everything. If they can't prove you said it, you didn't say it.",
            flavor_text: "\"I have no recollection of making that argument, Your Honor.\"",
            special_effect: Some("If the opponent's attack deals 0 damage (fully blocked), gain 2 RP next turn."),
        ),

        (
            key: "redirect_blame",
            name: "Redirect Blame",
            category: "Block",
            rp_cost: 2,
            damage: 0,
            block: 6,
            description: "Block damage and reflect 3 points back to the attacker.",
            flavor_text: "\"That was actually YOUR policy, if you recall. Section 12(b). YOUR signature.\"",
            special_effect: Some("Reflect 3 Credibility damage back to opponent."),
        ),

        (
            key: "procedural_objection",
            name: "Procedural Objection",
            category: "Block",
            rp_cost: 1,
            damage: 0,
            block: 8,
            description: "Object on procedural grounds. Their argument may be right, but they filed it wrong.",
            flavor_text: "\"Your argument was submitted in triplicate? I only count two copies. OVERRULED.\"",
            special_effect: None,
        ),

        (
            key: "cite_precedent",
            name: "Cite Precedent",
            category: "Block",
            rp_cost: 2,
            damage: 0,
            block: 10,
            description: "Reference a previous ruling. Strong defense. Whether the precedent is relevant is debatable.",
            flavor_text: "\"In the case of Taxpayer v. The Entire Government, the ruling was clear: I'm right.\"",
            special_effect: Some("If you played Cite Precedent last turn, gain +4 block (stacking defense)."),
        ),

        // =====================================================================
        // SPECIAL CARDS -- Unique Effects and Dirty Tricks
        // =====================================================================

        (
            key: "moving_the_goalposts",
            name: "Moving the Goalposts",
            category: "Special",
            rp_cost: 2,
            damage: 0,
            block: 0,
            description: "Change the criteria for winning. Opponent loses any accumulated 'winning' status.",
            flavor_text: "\"Actually, when I said 'balanced budget,' I meant something completely different. Let me redefine the terms.\"",
            special_effect: Some("Remove all positive status effects from opponent. If they had 'Momentum' (from consecutive attacks), remove it and deal 5 damage."),
        ),

        (
            key: "filibuster",
            name: "Filibuster",
            category: "Special",
            rp_cost: 4,
            damage: 0,
            block: 0,
            description: "Talk for so long that nobody can do anything. Skip the opponent's next turn entirely.",
            flavor_text: "\"And FURTHERMORE, in the fiscal year of 1847, the Taxeclast Revenue Authority established-- are you still listening? I'll start over from the beginning.\"",
            special_effect: Some("Opponent skips their next turn. Cannot be played two turns in a row."),
        ),

        (
            key: "leaked_memo",
            name: "Leaked Memo",
            category: "Special",
            rp_cost: 2,
            damage: 0,
            block: 0,
            description: "Reveal your opponent's next 2 planned cards. Knowledge is power. Leaked knowledge is more power.",
            flavor_text: "\"Funny story -- I found this memo in the waste bin. Shall I read it aloud?\"",
            special_effect: Some("Reveal opponent's next 2 card plays. Revealed cards deal 25% less damage."),
        ),

        (
            key: "bipartisan_agreement",
            name: "Bipartisan Agreement",
            category: "Special",
            rp_cost: 3,
            damage: 5,
            block: 5,
            description: "Find common ground. Both you and your opponent gain block. You also deal damage. Unity!",
            flavor_text: "\"We may disagree on everything, but we can agree that this debate is going nowhere. Let's agree on THAT.\"",
            special_effect: Some("Opponent also gains 5 Block. Yes, really. It's bipartisan."),
        ),

        (
            key: "executive_order",
            name: "Executive Order",
            category: "Special",
            rp_cost: 5,
            damage: 15,
            block: 0,
            description: "Bypass the debate entirely with raw authority. Massive damage. Can only be played once per debate.",
            flavor_text: "\"I've heard enough. BY EXECUTIVE ORDER: you are wrong. Meeting adjourned.\"",
            special_effect: Some("Can only be played once per debate. Ignores 50% of opponent's Block."),
        ),

        (
            key: "spin_doctor",
            name: "Spin Doctor",
            category: "Special",
            rp_cost: 2,
            damage: 0,
            block: 0,
            description: "Transform a bad situation into a good one. Convert your last damage taken into healing.",
            flavor_text: "\"What you call a 'devastating rebuttal,' I call a 'learning opportunity.'\"",
            special_effect: Some("Heal Credibility equal to the damage you took last turn (max 10)."),
        ),

        (
            key: "campaign_promise",
            name: "Campaign Promise",
            category: "Special",
            rp_cost: 0,
            damage: 0,
            block: 0,
            description: "Promise something amazing. Gain 3 RP immediately. But next turn, lose 2 RP. Promises have costs.",
            flavor_text: "\"I promise to cut taxes by 50% AND double spending! The math works out. Trust me.\"",
            special_effect: Some("Gain 3 RP immediately. Lose 2 RP at the start of next turn."),
        ),

        (
            key: "fact_check",
            name: "Fact Check",
            category: "Special",
            rp_cost: 1,
            damage: 0,
            block: 0,
            description: "Verify a claim. If opponent attacked last turn, deal 6 damage. If they blocked, draw 2 cards.",
            flavor_text: "\"Let me check that claim against the ACTUAL record... oh dear. Oh DEAR.\"",
            special_effect: Some("If opponent attacked last turn: deal 6 damage. If opponent blocked last turn: draw 2 cards. If neither: gain 2 Block."),
        ),

        (
            key: "subpoena",
            name: "Subpoena",
            category: "Special",
            rp_cost: 3,
            damage: 0,
            block: 0,
            description: "Force opponent to discard their highest-cost card. Legal compulsion is a powerful tool.",
            flavor_text: "\"You are hereby COMPELLED to surrender your best argument. Sign here. And here. Initial here.\"",
            special_effect: Some("Opponent discards their highest RP-cost card from hand. If their hand is empty, deal 8 damage instead."),
        ),

        (
            key: "government_shutdown",
            name: "Government Shutdown",
            category: "Special",
            rp_cost: 4,
            damage: 0,
            block: 0,
            description: "Neither player can play cards next turn. Both draw 3 cards. Reset the board.",
            flavor_text: "\"Due to a failure to reach an agreement, all debate operations have been SUSPENDED. Everyone go home.\"",
            special_effect: Some("Both players skip next turn. Both draw 3 cards. All temporary buffs/debuffs are cleared."),
        ),

        (
            key: "regulatory_capture",
            name: "Regulatory Capture",
            category: "Special",
            rp_cost: 3,
            damage: 0,
            block: 0,
            description: "Copy your opponent's last played card and play it yourself. If they had a good idea, steal it.",
            flavor_text: "\"That's a great argument. I'm going to use it. Against you. Right now.\"",
            special_effect: Some("Copy the effect of opponent's most recently played card. If it was an Attack, deal its damage. If Block, gain its block value. If Special, trigger its effect."),
        ),

        (
            key: "tax_reform",
            name: "Tax Reform",
            category: "Special",
            rp_cost: 2,
            damage: 0,
            block: 0,
            description: "Discard your entire hand and draw that many cards +1. Sometimes you need a fresh start.",
            flavor_text: "\"I'm throwing out the entire existing framework and starting from scratch. Yes, again. It's tradition.\"",
            special_effect: Some("Discard all cards in hand. Draw that many +1 new cards from your deck."),
        ),
    ],
)
